{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Upload Packet",
  "type": "object",
  "required": [
    "title",
    "thumbnail_file",
    "description",
    "audience_setting",
    "disclosures",
    "qa_passed"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 5
    },
    "thumbnail_file": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "audience_setting": {
      "type": "string"
    },
    "disclosures": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "qa_passed": {
      "type": "boolean"
    }
  }
}
